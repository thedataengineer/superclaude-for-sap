{
  "name": "@babamba2/superclaude-for-sap",
  "version": "0.6.7",
  "description": "SuperClaude for SAP — Claude Code plugin for SAP On-Premise S/4HANA development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sc4sap": "bridge/cli.cjs"
  },
  "files": [
    "dist",
    "agents",
    "bridge",
    "hooks",
    "scripts",
    "skills",
    "configs",
    ".claude-plugin",
    ".mcp.json",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-mcp-server.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@ast-grep/napi": "^0.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.7",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
